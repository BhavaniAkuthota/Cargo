    <!-- Human Remains Domestic Cases   -->
    <test name="createAndConfirmGuidedBookingHumanRemains_CARE_Adult_Domestic">
        <parameter name="url" value="si.deltacargo.com"></parameter>
        <parameter name="browser" value="chrome"></parameter>
        <parameter name="author" value="Bhavani"></parameter>
        <classes>
            <class name="com.delta.test.ui.GuidedBooking_HumanRemainsTest">
                <methods>
                    <include name="createAndConfirmGuidedBookingHumanRemains_CARE_Adult_Domestic"/>
                </methods>
            </class>
        </classes>
    </test>
