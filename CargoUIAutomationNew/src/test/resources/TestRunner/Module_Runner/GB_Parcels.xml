<!--GuidedBooking_Parcels-->
<!--1-->
    <test name="createAndConfirmGuidedBookingParcels_STANDARD_NA_Domestic">
        <parameter name="url" value="si.deltacargo.com"></parameter>
        <parameter name="browser" value="chrome"></parameter>
        <parameter name="author" value="Bhavani"></parameter>
        <classes>
            <class name="com.delta.test.ui.GuidedBooking_ParcelTest">
