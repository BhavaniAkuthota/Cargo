<!--Pharma Domestic Test Cases-->
    <test name="createAndConfirmGuidedBookingPharma_PHARMA_Pharma1ActiveContainer_Domestic">
        <parameter name="url" value="si.deltacargo.com"></parameter>
        <parameter name="browser" value="chrome"></parameter>
        <parameter name="author" value="Bhavani"></parameter>
        <classes>
            <class name="com.delta.test.ui.GuidedBooking_PharmaTest">
                <methods>
                    <include name="createAndConfirmGuidedBookingPharma_PHARMA_Pharma1ActiveContainer_Domestic"/>
                </methods>
            </class>
        </classes>
    </test>
