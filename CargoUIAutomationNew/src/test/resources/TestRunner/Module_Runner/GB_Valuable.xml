<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE suite SYSTEM "http://testng.org/testng-1.0.dtd">
<suite name="Cargo UI Automation" verbose="1" thread-count="1" parallel="false" >

<!--    <listeners>-->
<!--        <listener class-name="com.qa.ExtentReportListener.ExtentReporterNG" />-->
<!--    </listeners>-->

    <!--Domestic Valuables Test Cases-->
    <test name="createAndConfirmGuidedBookingValuables_SAFE_Valuegreaterthan25000USD_Domestic">
        <parameter name="url" value="si.deltacargo.com"></parameter>
        <parameter name="browser" value="chrome"></parameter>
        <parameter name="author" value="Bhavani"></parameter>
        <classes>
            <class name="com.delta.test.ui.GuidedBooking_ValuablesTest">
                <methods>
                    <include name="createAndConfirmGuidedBookingValuables_SAFE_Valuegreaterthan25000USD_Domestic"/>
                </methods>
            </class>
        </classes>
    </test>
    <test name="createAndConfirmGuidedBookingValuables_SAFE_Valuelessthan25000USD_Domestic">
        <parameter name="url" value="si.deltacargo.com"></parameter>
        <parameter name="browser" value="chrome"></parameter>
        <parameter name="author" value="Bhavani"></parameter>
        <classes>
            <class name="com.delta.test.ui.GuidedBooking_ValuablesTest">
                <methods>
                    <include name="createAndConfirmGuidedBookingValuables_SAFE_Valuelessthan25000USD_Domestic"/>
                </methods>
            </class>
        </classes>
    </test>
<!--    International Valuables Test Cases-->
    <test name="createAndConfirmGuidedBookingValuables_SAFE_Valuegreaterthan25000USD_International">
        <parameter name="url" value="si.deltacargo.com"></parameter>
        <parameter name="browser" value="chrome"></parameter>
        <parameter name="author" value="Bhavani"></parameter>
        <classes>
            <class name="com.delta.test.ui.GuidedBooking_ValuablesTest">
                <methods>
                    <include name="createAndConfirmGuidedBookingValuables_SAFE_Valuegreaterthan25000USD_International"/>
                </methods>
            </class>
        </classes>
    </test>
    <test name="createAndConfirmGuidedBookingValuables_SAFE_Valuelessthan25000USD_International">
        <parameter name="url" value="si.deltacargo.com"></parameter>
        <parameter name="browser" value="chrome"></parameter>
        <parameter name="author" value="Bhavani"></parameter>
        <classes>
            <class name="com.delta.test.ui.GuidedBooking_ValuablesTest">
                <methods>
                    <include name="createAndConfirmGuidedBookingValuables_SAFE_Valuelessthan25000USD_International"/>
                </methods>
            </class>
        </classes>
    </test>

</suite>