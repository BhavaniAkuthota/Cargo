<!--Parcellessthan16OZ Domestic Test Cases-->
    <test name="createAndConfirmGuidedBookingParcellessthan16OZ_DSH_NA_Domestic">
        <parameter name="url" value="si.deltacargo.com"></parameter>
        <parameter name="browser" value="chrome"></parameter>
        <parameter name="author" value="Sumit"></parameter>
        <classes>
            <class name="com.delta.test.ui.GuidedBooking_ParcelLessThan16OZTest">
                <methods>
                    <include name="createAndConfirmGuidedBookingParcellessthan16OZ_DSH_NA_Domestic"/>
                </methods>
            </class>
        </classes>
    </test>
